---
const otherProjects = [
  {
    title: 'Physarum Polycephalum Simulation',
    description: 'GPU-accelerated computational model of biological network formation — 100,000+ autonomous agents following local rules produce globally optimal transport networks. Demonstrates emergence, agent-based modeling, and high-performance parallel computation with custom GLSL shaders. Runs at 60fps.',
    tags: ['WebGL', 'GLSL', 'JavaScript', 'Agent-Based Modeling'],
    image: '/images/SlimeMoldCover.png',
    liveUrl: '#',
    sourceUrl: 'https://github.com/daniilguchua/slime-mold-simulation',
  },
  {
    title: 'ML Sentence Autocomplete',
    description: 'End-to-end ML pipeline built from scratch — no pretrained models. N-gram language modeling, word2vec embeddings (trained on 50K+ sentences), and beam search decoding. Full pipeline: data preprocessing → feature engineering → model training → inference API (Flask, sub-200ms). Demonstrates ML fundamentals without hiding behind frameworks.',
    tags: ['Python', 'NLTK', 'spaCy', 'Flask', 'NLP'],
    image: '/images/ml-autocomplete-cover.png',
    sourceUrl: 'https://github.com/daniilguchua/ml-sentence-autocomplete',
  },
  {
    title: 'Vestibular Rehabilitation Device',
    description: 'Medical rehabilitation device designed with clinicians at the Shirley Ryan AbilityLab. Modular foam platform with interchangeable inserts and adjustable weights that progressively challenge patients\' balance recovery. 3 iterative prototypes validated through PT feedback and patient observation.',
    tags: ['Product Design', 'CAD', 'User Research', 'Prototyping'],
    image: '/images/vestibular-cover.png',
    credential: 'Shirley Ryan AbilityLab',
  },
];

const axiomStats = [
  { value: 95, suffix: '%', prefix: '~', label: 'Auto-Repair' },
  { value: 31, suffix: '', prefix: '', label: 'API Endpoints' },
  { value: 219, suffix: '', prefix: '', label: 'Tests' },
  { value: 4, suffix: '-Tier', prefix: '', label: 'Pipeline' },
  { value: 3, suffix: '', prefix: '', label: 'AI Personas' },
];

const axiomTags = ['Python', 'Flask', 'Gemini 2.5 Pro', 'LangChain', 'FAISS', 'RAG', 'Mermaid.js', 'Three.js', 'Docker', 'SQLite', 'pytest'];

---

<section class="work" id="work">
  <div class="work__inner container">
    <div class="work__header" data-reveal>
      <span class="section-label">Selected Work</span>
      <h2 class="section-title work__title">What I've Built</h2>
    </div>

    <!-- Axiom Engine — Vertical Showcase -->
    <div class="work__axiom-wrapper" id="axiom-pin-wrapper">
      <!-- Header — centered -->
      <div class="work__axiom-header" data-reveal>
        <span class="work__flagship-badge">Flagship Project</span>
        <h3 class="work__axiom-title">Axiom Engine</h3>
        <p class="work__axiom-tagline">Not another ChatGPT wrapper. A production AI platform with self-healing compilation, semantic caching, and 10,000 lines of tested infrastructure.</p>
        <div class="work__axiom-stats-inline" id="axiom-stats">
          {axiomStats.map((stat, i) => (
            <>
              <span class="work__inline-stat">
                <span class="work__inline-stat-value" data-count={stat.value} data-suffix={stat.suffix} data-prefix={stat.prefix}>0</span>
                <span class="work__inline-stat-label">{stat.label}</span>
              </span>
              {i < axiomStats.length - 1 && <span class="work__inline-stat-sep">&middot;</span>}
            </>
          ))}
        </div>
      </div>

      <!-- Terminal — full-width hero -->
      <div class="work__axiom-terminal-wrap" data-reveal>
        <div class="work__screen axiom-terminal">
          <div class="work__screen-bar">
            <span class="work__dot work__dot--red"></span>
            <span class="work__dot work__dot--yellow"></span>
            <span class="work__dot work__dot--green"></span>
            <span class="work__screen-url">axiom-engine &mdash; python app.py</span>
            <span class="work__terminal-status">&#x25CF; LIVE</span>
          </div>
          <div class="work__screen-body">
            <div class="work__terminal" id="axiom-terminal">
              <p class="work__terminal-line"><span class="t-prompt">$</span> <span class="t-cmd">axiom</span> generate <span class="t-string">"dijkstra's shortest path"</span> <span class="t-flag">--persona</span> explorer</p>
              <p class="work__terminal-line t-dim"><span class="t-ts">[00:00.012]</span> <span class="t-kw">VALIDATE</span> input sanitized &mdash; 11 injection patterns screened <span class="t-pass">&#x2713;</span></p>
              <p class="work__terminal-line t-dim"><span class="t-ts">[00:00.034]</span> <span class="t-kw">CACHE</span> SHA-256 miss &rarr; cosine search (&ge;0.80) &rarr; miss</p>
              <p class="work__terminal-line"><span class="t-ts">[00:00.041]</span> <span class="t-kw t-kw--purple">PERSONA</span> Explorer loaded <span class="t-dim">(temp=0.55, nodes~6, analogies=ON)</span></p>
              <p class="work__terminal-line t-stream"><span class="t-ts">[00:00.089]</span> <span class="t-kw t-kw--purple">STREAM</span> Gemini 2.5 Pro &rarr; 847 tokens <span class="t-dim">(1.2s, $0.003)</span></p>
              <p class="work__terminal-line"><span class="t-ts">[00:01.301]</span> <span class="t-kw">REPAIR</span> Tier 1: 23 regex &rarr; <span class="t-pass">PASS</span> <span class="t-dim">(5ms, $0)</span></p>
              <p class="work__terminal-line"><span class="t-ts">[00:01.306]</span> <span class="t-kw">RENDER</span> Mermaid compile &rarr; 6 nodes, 7 edges <span class="t-pass">&#x2713;</span></p>
              <p class="work__terminal-line t-success"><span class="t-ts">[00:01.340]</span> <span class="t-kw t-kw--green">DONE</span> Pipeline complete &mdash; cached for 24h <span class="t-pass">&#x2713; &#x2713;</span></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Features — 3x2 grid -->
      <div class="work__axiom-features" data-reveal>
        <div class="work__features-grid">
          <div class="work__feature-card">
            <span class="work__feature-title">Self-Healing Mermaid Compiler</span>
            <p class="work__feature-desc">Hand-written syntax repair compiler. 4-tier escalation: 23 ordered regex transforms (5ms, $0) &rarr; 13-phase JS sanitizer with string literal masking from compiler design (10ms, $0) &rarr; LLM-assisted repair. ~95% auto-repair, ~85% at zero cost. Cuts repair spend 83% vs naive retry.</p>
          </div>
          <div class="work__feature-card">
            <span class="work__feature-title">Production RAG Pipeline</span>
            <p class="work__feature-desc">PyMuPDF extraction &rarr; LangChain RecursiveCharacterTextSplitter (1K chars, 100 overlap) &rarr; 768-dim Gemini embeddings &rarr; FAISS IndexFlatL2 vector search &rarr; top-6 retrieval with word-level deduplication (&gt;60% overlap filtering). 41 phrase-based intent triggers route across 4 response modes.</p>
          </div>
          <div class="work__feature-card">
            <span class="work__feature-title">Semantic Caching System</span>
            <p class="work__feature-desc">Two-tier cost optimization eliminating redundant Gemini API calls. SHA-256 exact hash match &rarr; embedding-based cosine similarity &ge;0.80. Broken simulation tracker with retry budget (max 3), 24h cooldown, permanent-broken status. Only verified-complete simulations cached.</p>
          </div>
          <div class="work__feature-card">
            <span class="work__feature-title">AI Persona Engine (Strategy Pattern)</span>
            <p class="work__feature-desc">Three personas from cognitive science research &mdash; Explorer (~6 nodes, temp 0.55), Engineer (9&ndash;12 nodes, 0.40), Architect (12&ndash;18 with subgraphs, 0.30). Single parameter swaps prompt, temperature, complexity, and pedagogy. 196-line Mermaid Syntax Firewall constrains output.</p>
          </div>
          <div class="work__feature-card">
            <span class="work__feature-title">Security &amp; Concurrency</span>
            <p class="work__feature-desc">11 compiled regex prompt injection detectors. Per-IP+session token bucket rate limiting. Thread-safe sessions with RLock, 60-min TTL, LRU eviction at 1,000 sessions, background daemon cleanup. Path traversal prevention. Input length enforcement (10K char max).</p>
          </div>
          <div class="work__feature-card">
            <span class="work__feature-title">MLOps &amp; Training Data Pipeline</span>
            <p class="work__feature-desc">Ghost testing captures every repair across 5 sanitization pipeline combinations. 10-table SQLite schema (WAL mode, auto-migration) storing supervised learning triples: (broken_input, tier, repaired_output). Building toward fine-tuning a LLaMA-based repair model.</p>
          </div>
        </div>
      </div>

      <!-- What's Next -->
      <div class="work__axiom-roadmap" data-reveal>
        <span class="work__roadmap-label">What's Next</span>
        <div class="work__roadmap-items">
          <div class="work__roadmap-item">
            <span class="work__roadmap-title">ML-Powered Repair Model</span>
            <p class="work__roadmap-desc">Fine-tune LLaMA on the repair corpus already being collected. Target: replace hand-written regex with a learned repair function &mdash; faster, more generalizable.</p>
          </div>
          <div class="work__roadmap-item">
            <span class="work__roadmap-title">WebSocket Streaming</span>
            <p class="work__roadmap-desc">Replace HTTP streaming with true bidirectional WebSocket connections for real-time collaborative sessions and lower continuation latency.</p>
          </div>
          <div class="work__roadmap-item">
            <span class="work__roadmap-title">Adaptive Learning Engine</span>
            <p class="work__roadmap-desc">Use collected feedback data + session analytics to automatically suggest persona and complexity &mdash; personalized difficulty progression per student.</p>
          </div>
        </div>
      </div>

      <!-- Tags + CTAs — bottom -->
      <div class="work__axiom-footer" data-reveal>
        <div class="work__tags">
          {axiomTags.map((tag) => (
            <span class="work__tag">{tag}</span>
          ))}
        </div>
        <div class="work__actions">
          <a href={`${import.meta.env.BASE_URL}projects/axiom-engine`} class="work__btn work__btn--primary">
            View Case Study
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="https://github.com/daniilguchua/axiom-engine" target="_blank" rel="noopener noreferrer" class="work__btn work__btn--secondary">
            GitHub
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Other Projects Grid -->
    <div class="work__other-header" data-reveal>
      <span class="section-label">More Projects</span>
    </div>
    <div class="work__grid">
      {otherProjects.map((project, i) => (
        <article class="work__card" data-tilt data-reveal style={`transition-delay: ${i * 0.1}s`}>
          <div class="work__card-glow"></div>
          <div class="work__card-image">
            <img src={`${import.meta.env.BASE_URL}${project.image.replace(/^\//, '')}`} alt={project.title} loading="lazy" />
          </div>
          <div class="work__card-content">
            <h3 class="work__card-title">{project.title}</h3>
            {project.credential && (
              <span class="work__card-credential">{project.credential}</span>
            )}
            <p class="work__card-desc">{project.description}</p>
            <div class="work__card-tags">
              {project.tags.map((tag) => (
                <span class="work__tag">{tag}</span>
              ))}
            </div>
            <div class="work__card-links">
              {project.liveUrl && (
                <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="work__card-link">
                  Live Demo
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
              {project.sourceUrl && (
                <a href={project.sourceUrl} target="_blank" rel="noopener noreferrer" class="work__card-link">
                  Source Code
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .work {
    padding: var(--spacing-section) 0;
    /* no tint — clean dark */
  }

  .work__header {
    margin-bottom: 3rem;
  }

  .work__title {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work__title.revealed {
    clip-path: inset(0 0% 0 0);
  }

  /* ---- Axiom Vertical Showcase ---- */
  .work__axiom-wrapper {
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding: 3rem 0;
  }

  .work__axiom-header {
    text-align: center;
  }

  .work__flagship-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(14, 165, 233, 0.20);
    background: transparent;
    padding: 0.5rem 1.25rem;
    border-radius: var(--radius-full);
    display: inline-block;
    margin-bottom: 1rem;
  }

  .work__axiom-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .work__axiom-tagline {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-tertiary);
    max-width: 480px;
    margin: 0 auto 1.5rem;
    line-height: 1.5;
  }

  .work__axiom-stats-inline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .work__inline-stat {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .work__inline-stat-value {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .work__inline-stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .work__inline-stat-sep {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  /* Terminal */
  .work__axiom-terminal-wrap {
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
  }

  .work__screen {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .axiom-terminal {
    border-color: rgba(14, 165, 233, 0.15);
    box-shadow: 0 0 40px rgba(14, 165, 233, 0.06), 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .work__screen-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: linear-gradient(135deg, #0d1117, #161b22);
    border-bottom: 1px solid rgba(14, 165, 233, 0.10);
  }

  .work__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .work__dot--red { background: #ff5f57; }
  .work__dot--yellow { background: #febc2e; }
  .work__dot--green { background: #28c840; }

  .work__screen-url {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin-left: 8px;
  }

  .work__terminal-status {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-green);
    letter-spacing: 0.08em;
    animation: status-pulse 2s ease-in-out infinite;
  }

  @keyframes status-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .work__screen-body {
    padding: 1.25rem;
  }

  .work__terminal {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .work__terminal-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Syntax-highlighted terminal tokens */
  .t-prompt { color: var(--color-text-tertiary); margin-right: 0.3rem; }
  .t-cmd { color: var(--color-accent-bright); font-weight: 600; }
  .t-string { color: var(--color-cat-backend); }
  .t-flag { color: var(--color-cat-ai); }
  .t-kw { color: var(--color-accent); font-weight: 600; letter-spacing: 0.05em; }
  .t-kw--purple { color: var(--color-cat-ai); }
  .t-kw--green { color: var(--color-green); }
  .t-ts { color: var(--color-text-muted); font-size: 0.65rem; }
  .t-dim { color: var(--color-text-muted); }
  .t-stream { color: var(--color-cat-ai); }
  .t-success { color: var(--color-green); }
  .t-pass { color: var(--color-green); }

  /* Feature Cards — 2x2 grid */
  .work__axiom-features {
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
  }

  .work__features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .work__feature-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    transition: border-color 0.2s ease;
  }

  .work__feature-card:hover {
    border-color: var(--color-border-hover);
  }

  .work__feature-title {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    display: block;
    margin-bottom: 0.4rem;
  }

  .work__feature-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: 1.5;
    margin: 0;
  }

  /* What's Next Roadmap */
  .work__axiom-roadmap {
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
  }

  .work__roadmap-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.75rem;
  }

  .work__roadmap-items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  .work__roadmap-item {
    background: rgba(14, 165, 233, 0.03);
    border: 1px solid rgba(14, 165, 233, 0.10);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
  }

  .work__roadmap-title {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    display: block;
    margin-bottom: 0.3rem;
  }

  .work__roadmap-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .work__roadmap-items {
      grid-template-columns: 1fr;
    }
  }

  /* Tags + CTAs footer */
  .work__axiom-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .work__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4rem;
  }

  .work__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    border: 1px solid var(--color-border);
    background: transparent;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
  }

  .work__actions {
    display: flex;
    gap: 0.75rem;
  }

  .work__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .work__btn--primary {
    color: var(--color-text-primary);
    background: transparent;
    border: 1px solid var(--color-border-hover);
  }

  .work__btn--primary:hover {
    border-color: var(--color-accent);
    background: rgba(14, 165, 233, 0.06);
    transform: translateY(-1px);
    color: var(--color-text-primary);
  }

  .work__btn--secondary {
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    background: transparent;
  }

  .work__btn--secondary:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
  }

  /* ---- Other Projects ---- */
  .work__other-header {
    margin-bottom: 2rem;
  }

  .work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .work__card {
    position: relative;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.3s ease;
    will-change: transform;
  }

  .work__card:hover {
    border-color: rgba(14, 165, 233, 0.12);
  }

  .work__card-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(14, 165, 233, 0.08),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
    z-index: 0;
  }

  .work__card:hover .work__card-glow {
    opacity: 1;
  }

  .work__card-image {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .work__card-image img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .work__card:hover .work__card-image img {
    transform: scale(1.03);
  }

  .work__card-content {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
  }

  .work__card-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .work__card-credential {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.35rem;
  }

  .work__card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .work__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .work__card-links {
    display: flex;
    gap: 1.25rem;
  }

  .work__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }

  .work__card-link:hover {
    color: var(--color-text-primary);
  }

  /* ---- Tablet ---- */
  @media (max-width: 1024px) and (min-width: 769px) {
    .work__features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .work__axiom-title {
      font-size: var(--text-3xl);
    }

    .work__axiom-terminal-wrap,
    .work__axiom-features {
      max-width: 100%;
    }

    .work__features-grid {
      grid-template-columns: 1fr;
    }

    .work__grid {
      grid-template-columns: 1fr;
    }

    .work__actions {
      flex-direction: column;
    }

    .work__btn {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work__title {
      clip-path: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Clip-path title reveal
  const workTitle = document.querySelector('.work__title');
  if (workTitle && !reducedMotion) {
    ScrollTrigger.create({
      trigger: workTitle,
      start: 'top 85%',
      once: true,
      onEnter: () => workTitle.classList.add('revealed'),
    });
  }

  // Stat counter animation
  const statsSection = document.getElementById('axiom-stats');
  if (statsSection && !reducedMotion) {
    const statValues = statsSection.querySelectorAll('.work__inline-stat-value');

    ScrollTrigger.create({
      trigger: statsSection,
      start: 'top 80%',
      once: true,
      onEnter: () => {
        statValues.forEach((el) => {
          const target = parseInt(el.getAttribute('data-count') || '0', 10);
          const suffix = el.getAttribute('data-suffix') || '';
          const prefix = el.getAttribute('data-prefix') || '';
          const obj = { val: 0 };

          gsap.to(obj, {
            val: target,
            duration: 1.8,
            ease: 'power2.out',
            onUpdate: () => {
              const formatted = Math.round(obj.val).toLocaleString();
              (el as HTMLElement).textContent = prefix + formatted + suffix;
            },
          });
        });
      },
    });
  } else if (statsSection) {
    statsSection.querySelectorAll('.work__inline-stat-value').forEach((el) => {
      const target = el.getAttribute('data-count') || '0';
      const suffix = el.getAttribute('data-suffix') || '';
      const prefix = el.getAttribute('data-prefix') || '';
      (el as HTMLElement).textContent = prefix + parseInt(target, 10).toLocaleString() + suffix;
    });
  }

  // Terminal line-by-line reveal
  const terminal = document.getElementById('axiom-terminal');
  if (terminal && !reducedMotion) {
    const lines = terminal.querySelectorAll('.work__terminal-line');
    lines.forEach((line) => {
      (line as HTMLElement).style.opacity = '0';
      (line as HTMLElement).style.transform = 'translateX(-8px)';
    });

    ScrollTrigger.create({
      trigger: terminal,
      start: 'top 75%',
      once: true,
      onEnter: () => {
        lines.forEach((line, i) => {
          gsap.to(line, {
            opacity: 1,
            x: 0,
            duration: 0.4,
            delay: i * 0.25,
            ease: 'power2.out',
          });
        });
      },
    });
  }

  // 3D perspective tilt + glow border on project cards
  const isDesktop = window.matchMedia('(min-width: 769px) and (pointer: fine)').matches;
  if (isDesktop && !reducedMotion) {
    document.querySelectorAll('[data-tilt]').forEach((card) => {
      const glowEl = card.querySelector('.work__card-glow') as HTMLElement;

      card.addEventListener('mousemove', (e: Event) => {
        const ev = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        const x = ev.clientX - rect.left;
        const y = ev.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;

        const rotateX = ((y - centerY) / centerY) * -6;
        const rotateY = ((x - centerX) / centerX) * 6;

        gsap.to(card, {
          rotateX,
          rotateY,
          transformPerspective: 800,
          duration: 0.3,
          ease: 'power2.out',
        });

        if (glowEl) {
          const percentX = (x / rect.width) * 100;
          const percentY = (y / rect.height) * 100;
          (card as HTMLElement).style.setProperty('--mouse-x', `${percentX}%`);
          (card as HTMLElement).style.setProperty('--mouse-y', `${percentY}%`);
        }
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.6,
          ease: 'elastic.out(1, 0.3)',
        });
      });
    });
  }
</script>
