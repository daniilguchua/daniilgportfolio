---
const otherProjects = [
  {
    title: 'Physarum Polycephalum Simulation',
    description: 'GPU-accelerated WebGL simulation of Physarum polycephalum — the slime mold that solves mazes. 100,000+ autonomous agents follow deposit-sense-turn rules on a pheromone diffusion field, producing emergent transport networks that rival human-designed infrastructure. Runs at 60fps using custom GLSL shaders for parallel agent computation and Gaussian blur diffusion.',
    tags: ['WebGL', 'GLSL', 'JavaScript', 'Agent-Based Modeling'],
    image: '/images/SlimeMoldCover.png',
    liveUrl: '#',
    sourceUrl: 'https://github.com/daniilguchua/slime-mold-simulation',
  },
  {
    title: 'ML Sentence Autocomplete',
    description: 'Sentence completion engine built from scratch — no pretrained transformers. Combines n-gram frequency models, word2vec embeddings, and beam search decoding to predict contextually relevant completions. Trained on 50K+ sentences, served via Flask API with sub-200ms inference.',
    tags: ['Python', 'NLTK', 'spaCy', 'Flask', 'NLP'],
    image: '/images/ml-autocomplete-cover.png',
    sourceUrl: 'https://github.com/daniilguchua/ml-sentence-autocomplete',
  },
  {
    title: 'Vestibular Rehabilitation Device',
    description: 'Medical rehabilitation device designed with clinicians at the Shirley Ryan AbilityLab. Modular foam platform with interchangeable inserts and adjustable weights that progressively challenge patients\' balance recovery. 3 iterative prototypes validated through PT feedback and patient observation.',
    tags: ['Product Design', 'CAD', 'User Research', 'Prototyping'],
    image: '/images/vestibular-cover.png',
    credential: 'Shirley Ryan AbilityLab',
  },
];

const axiomStats = [
  { value: 10000, suffix: '+', prefix: '', label: 'Lines of Code' },
  { value: 64, suffix: '', prefix: '', label: 'Source Files' },
  { value: 31, suffix: '', prefix: '', label: 'API Endpoints' },
  { value: 4, suffix: '-Tier', prefix: '', label: 'Repair Pipeline' },
  { value: 3, suffix: '', prefix: '', label: 'AI Personas' },
];

const axiomTags = ['Python', 'Flask', 'Gemini 2.5 Pro', 'LangChain', 'FAISS', 'RAG', 'Mermaid.js', 'Three.js', 'Docker', 'SQLite', 'pytest'];

const pipelineNodes = ['Validate', 'Cache', 'Persona', 'Gemini Stream', 'Sanitize', 'Render', 'Verify'];
---

<section class="work" id="work">
  <div class="work__inner container">
    <div class="work__header" data-reveal>
      <span class="section-label">Selected Work</span>
      <h2 class="section-title work__title">What I've Built</h2>
    </div>

    <!-- Axiom Engine — Scroll-Pinned Showcase -->
    <div class="work__axiom-wrapper" id="axiom-pin-wrapper">
      <div class="work__axiom-stage">
        <!-- Left: persistent info -->
        <div class="work__axiom-left">
          <span class="work__flagship-badge">Flagship Project</span>
          <h3 class="work__axiom-title">Axiom Engine</h3>
          <p class="work__axiom-tagline">See Algorithms Think — 64 source files, 8 Flask blueprints, production-grade AI infrastructure</p>

          <div class="work__stats" id="axiom-stats">
            {axiomStats.map((stat) => (
              <div class="work__stat">
                <span class="work__stat-value" data-count={stat.value} data-suffix={stat.suffix} data-prefix={stat.prefix}>0</span>
                <span class="work__stat-label">{stat.label}</span>
              </div>
            ))}
          </div>

          <div class="work__tags">
            {axiomTags.map((tag) => (
              <span class="work__tag">{tag}</span>
            ))}
          </div>

          <div class="work__actions">
            <a href="/projects/axiom-engine" class="work__btn work__btn--primary">
              View Case Study
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M13 8L8 3M13 8L8 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="https://github.com/daniilguchua/axiom-engine" target="_blank" rel="noopener noreferrer" class="work__btn work__btn--secondary">
              GitHub
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: sequential panels -->
        <div class="work__axiom-right" id="axiom-panels">
          <!-- Panel 1: Terminal Preview -->
          <div class="axiom-panel axiom-panel--active" id="panel-overview">
            <div class="work__screen">
              <div class="work__screen-bar">
                <span class="work__dot work__dot--red"></span>
                <span class="work__dot work__dot--yellow"></span>
                <span class="work__dot work__dot--green"></span>
                <span class="work__screen-url">axiom.engine / visualize</span>
              </div>
              <div class="work__screen-body">
                <div class="work__terminal">
                  <p class="work__terminal-line"><span class="work__terminal-prompt">&gt;</span> axiom generate "dijkstra's shortest path" --persona explorer</p>
                  <p class="work__terminal-line work__terminal-line--dim"><span class="work__terminal-prompt">&gt;</span> input validation passed (11 injection patterns screened)</p>
                  <p class="work__terminal-line work__terminal-line--dim"><span class="work__terminal-prompt">&gt;</span> checking semantic cache... SHA-256 miss &rarr; cosine search (&ge;0.80)</p>
                  <p class="work__terminal-line work__terminal-line--accent"><span class="work__terminal-prompt">&gt;</span> assembling Explorer persona (temp=0.55, ~6 nodes)</p>
                  <p class="work__terminal-line work__terminal-line--dim"><span class="work__terminal-prompt">&gt;</span> streaming from Gemini 2.5 Pro...</p>
                  <p class="work__terminal-line work__terminal-line--accent"><span class="work__terminal-prompt">&gt;</span> Tier 1 sanitizer: 23 regex transforms applied (5ms, $0 cost)</p>
                  <p class="work__terminal-line work__terminal-line--success"><span class="work__terminal-prompt">&gt;</span> all steps rendered. caching verified-complete simulation.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 2: Architecture Pipeline -->
          <div class="axiom-panel" id="panel-pipeline">
            <div class="work__pipeline-card">
              <span class="work__pipeline-label">Request Pipeline</span>
              <div class="work__pipeline-flow">
                {pipelineNodes.map((node, i) => (
                  <>
                    <div class="work__pipeline-node" style={`animation-delay: ${i * 0.15}s`}>
                      <span class="work__pipeline-node-name">{node}</span>
                    </div>
                    {i < pipelineNodes.length - 1 && (
                      <span class="work__pipeline-arrow" style={`animation-delay: ${i * 0.15 + 0.08}s`}>&rarr;</span>
                    )}
                  </>
                ))}
              </div>
              <p class="work__pipeline-desc">
                Every query flows through input validation (11 injection patterns), two-tier semantic cache (SHA-256 &rarr; cosine similarity), persona-specific prompt assembly with a 196-line Mermaid Syntax Firewall, Gemini 2.5 Pro streaming, 4-tier Mermaid sanitization, and client-side rendering with completion verification.
              </p>
            </div>
          </div>

          <!-- Panel 3: Feature Cards -->
          <div class="axiom-panel" id="panel-features">
            <div class="work__features-grid">
              <div class="work__feature-card">
                <span class="work__feature-title">Self-Healing Mermaid Compiler</span>
                <p class="work__feature-desc">A custom syntax repair compiler with 4-tier escalation. 23+ ordered regex transforms in Python, a 13-phase JavaScript sanitizer with string literal masking (borrowed from compiler design), and LLM-assisted repair as a last resort. Recovers ~95% of broken LLM output without any API call.</p>
              </div>
              <div class="work__feature-card">
                <span class="work__feature-title">RAG + Semantic Cache</span>
                <p class="work__feature-desc">Upload any PDF &rarr; PyMuPDF extraction &rarr; 768-dim embeddings &rarr; FAISS vector search. 41 phrase-based intent triggers route queries to DOCUMENT_QA or DOCUMENT_SIMULATION mode. Two-tier cache: SHA-256 exact match, then cosine similarity &ge;0.80. Zero redundant API calls.</p>
              </div>
              <div class="work__feature-card">
                <span class="work__feature-title">Three AI Personas (Strategy Pattern)</span>
                <p class="work__feature-desc">Explorer (warm, analogies, ~6 nodes), Engineer (pragmatic, pseudocode, 9-12 nodes), Architect (research-grade, subgraphs, 12-18 nodes). Each swaps the entire system prompt, temperature, complexity target, and pedagogical approach via a single difficulty parameter.</p>
              </div>
              <div class="work__feature-card">
                <span class="work__feature-title">Agentic Error Recovery</span>
                <p class="work__feature-desc">The self-healing pipeline is functionally an autonomous agent loop: observe render failure &rarr; diagnose error type &rarr; select repair strategy &rarr; execute fix &rarr; verify result. Ghost testing captures every repair attempt for data-driven pipeline optimization.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Other Projects Grid -->
    <div class="work__other-header" data-reveal>
      <span class="section-label">More Projects</span>
    </div>
    <div class="work__grid">
      {otherProjects.map((project, i) => (
        <article class="work__card" data-tilt data-reveal style={`transition-delay: ${i * 0.1}s`}>
          <div class="work__card-glow"></div>
          <div class="work__card-image">
            <img src={project.image} alt={project.title} loading="lazy" />
          </div>
          <div class="work__card-content">
            <h3 class="work__card-title">{project.title}</h3>
            {project.credential && (
              <span class="work__card-credential">{project.credential}</span>
            )}
            <p class="work__card-desc">{project.description}</p>
            <div class="work__card-tags">
              {project.tags.map((tag) => (
                <span class="work__tag">{tag}</span>
              ))}
            </div>
            <div class="work__card-links">
              {project.liveUrl && (
                <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="work__card-link">
                  Live Demo
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
              {project.sourceUrl && (
                <a href={project.sourceUrl} target="_blank" rel="noopener noreferrer" class="work__card-link">
                  Source Code
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M4 12L12 4M12 4H5M12 4V11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .work {
    padding: var(--spacing-section) 0;
  }

  .work__header {
    margin-bottom: 3rem;
  }

  .work__title {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .work__title.revealed {
    clip-path: inset(0 0% 0 0);
  }

  /* ---- Axiom Pinned Showcase ---- */
  .work__axiom-wrapper {
    margin-bottom: 5rem;
    min-height: 100vh;
  }

  .work__axiom-stage {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }

  .work__axiom-left {
    position: sticky;
    top: 100px;
  }

  .work__flagship-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(14, 165, 233, 0.2);
    background: rgba(14, 165, 233, 0.05);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-full);
    display: inline-block;
    margin-bottom: 1rem;
    box-shadow: 0 0 20px rgba(14, 165, 233, 0.08);
  }

  .work__axiom-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
  }

  .work__axiom-tagline {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-tertiary);
    font-style: italic;
    margin-bottom: 2rem;
  }

  .work__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 1.25rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: 1.5rem;
  }

  .work__stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .work__stat-value {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .work__stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .work__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .work__tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    background: transparent;
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .work__tag:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-tertiary);
  }

  .work__actions {
    display: flex;
    gap: 0.75rem;
  }

  .work__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .work__btn--primary {
    color: var(--color-text-primary);
    background: transparent;
    border: 1px solid var(--color-border-glow);
  }

  .work__btn--primary:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(14, 165, 233, 0.3);
    box-shadow: 0 0 20px var(--color-accent-glow);
    color: var(--color-text-primary);
  }

  .work__btn--secondary {
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    background: transparent;
  }

  .work__btn--secondary:hover {
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
  }

  /* ---- Right Panel System ---- */
  .work__axiom-right {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .axiom-panel {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .axiom-panel--active,
  .axiom-panel.revealed {
    opacity: 1;
    transform: translateY(0);
  }

  /* Terminal Preview */
  .work__screen {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .work__screen-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-border);
  }

  .work__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .work__dot--red { background: #ff5f57; }
  .work__dot--yellow { background: #febc2e; }
  .work__dot--green { background: #28c840; }

  .work__screen-url {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin-left: 8px;
  }

  .work__screen-body {
    padding: 1.25rem;
  }

  .work__terminal {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .work__terminal-line {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .work__terminal-line--dim {
    color: var(--color-text-muted);
  }

  .work__terminal-line--accent {
    color: var(--color-accent);
  }

  .work__terminal-line--success {
    color: var(--color-green);
  }

  .work__terminal-prompt {
    color: var(--color-text-tertiary);
    margin-right: 0.3rem;
  }

  /* Architecture Pipeline */
  .work__pipeline-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
  }

  .work__pipeline-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 1rem;
  }

  .work__pipeline-flow {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .work__pipeline-node {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-glow);
    border-radius: var(--radius-sm);
    padding: 0.35rem 0.65rem;
  }

  .work__pipeline-node-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .work__pipeline-arrow {
    color: var(--color-accent);
    font-size: var(--text-sm);
  }

  .work__pipeline-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: 1.6;
    margin: 0;
  }

  /* Feature Cards */
  .work__features-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .work__feature-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    border-left: 2px solid transparent;
    border-image: linear-gradient(to bottom, var(--color-accent), var(--color-ir-4)) 1;
    border-image-slice: 0 0 0 1;
    transition: border-color 0.3s ease;
  }

  .work__feature-card:hover {
    border-color: var(--color-border-hover);
  }

  .work__feature-title {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    display: block;
    margin-bottom: 0.4rem;
  }

  .work__feature-desc {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    line-height: 1.6;
    margin: 0;
  }

  /* ---- Other Projects ---- */
  .work__other-header {
    margin-bottom: 2rem;
  }

  .work__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .work__card {
    position: relative;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.3s ease;
    will-change: transform;
  }

  .work__card:hover {
    border-color: var(--color-border-hover);
  }

  .work__card-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: radial-gradient(
      circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(14, 165, 233, 0.08),
      transparent 50%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }

  .work__card:hover .work__card-glow {
    opacity: 1;
  }

  .work__card-image {
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .work__card-image img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .work__card:hover .work__card-image img {
    transform: scale(1.03);
  }

  .work__card-content {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
  }

  .work__card-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .work__card-credential {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.35rem;
  }

  .work__card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .work__card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .work__card-links {
    display: flex;
    gap: 1.25rem;
  }

  .work__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }

  .work__card-link:hover {
    color: var(--color-text-primary);
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .work__axiom-stage {
      grid-template-columns: 1fr;
    }

    .work__axiom-left {
      position: relative;
      top: auto;
    }

    .work__stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .work__grid {
      grid-template-columns: 1fr;
    }

    .work__actions {
      flex-direction: column;
    }

    .work__btn {
      justify-content: center;
    }

    .axiom-panel {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .work__title {
      clip-path: none;
    }

    .axiom-panel {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 768px)').matches;

  // Clip-path title reveal
  const workTitle = document.querySelector('.work__title');
  if (workTitle && !reducedMotion) {
    ScrollTrigger.create({
      trigger: workTitle,
      start: 'top 85%',
      once: true,
      onEnter: () => workTitle.classList.add('revealed'),
    });
  }

  // Panel reveal on scroll (desktop: staggered via ScrollTrigger, mobile: use data-reveal observer)
  if (!isMobile && !reducedMotion) {
    const panels = document.querySelectorAll('.axiom-panel');
    panels.forEach((panel, i) => {
      ScrollTrigger.create({
        trigger: panel,
        start: 'top 80%',
        once: true,
        onEnter: () => {
          gsap.to(panel, {
            opacity: 1,
            y: 0,
            duration: 0.7,
            delay: i * 0.15,
            ease: 'power3.out',
          });
        },
      });
    });
  }

  // Stat counter animation
  const statsSection = document.getElementById('axiom-stats');
  if (statsSection && !reducedMotion) {
    const statValues = statsSection.querySelectorAll('.work__stat-value');

    ScrollTrigger.create({
      trigger: statsSection,
      start: 'top 80%',
      once: true,
      onEnter: () => {
        statValues.forEach((el) => {
          const target = parseInt(el.getAttribute('data-count') || '0', 10);
          const suffix = el.getAttribute('data-suffix') || '';
          const prefix = el.getAttribute('data-prefix') || '';
          const obj = { val: 0 };

          gsap.to(obj, {
            val: target,
            duration: 1.8,
            ease: 'power2.out',
            onUpdate: () => {
              const formatted = Math.round(obj.val).toLocaleString();
              (el as HTMLElement).textContent = prefix + formatted + suffix;
            },
          });
        });
      },
    });
  } else if (statsSection) {
    statsSection.querySelectorAll('.work__stat-value').forEach((el) => {
      const target = el.getAttribute('data-count') || '0';
      const suffix = el.getAttribute('data-suffix') || '';
      const prefix = el.getAttribute('data-prefix') || '';
      (el as HTMLElement).textContent = prefix + parseInt(target, 10).toLocaleString() + suffix;
    });
  }

  // 3D perspective tilt + glow border on project cards
  const isDesktop = window.matchMedia('(min-width: 769px) and (pointer: fine)').matches;
  if (isDesktop && !reducedMotion) {
    document.querySelectorAll('[data-tilt]').forEach((card) => {
      const glowEl = card.querySelector('.work__card-glow') as HTMLElement;

      card.addEventListener('mousemove', (e: Event) => {
        const ev = e as MouseEvent;
        const rect = (card as HTMLElement).getBoundingClientRect();
        const x = ev.clientX - rect.left;
        const y = ev.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;

        const rotateX = ((y - centerY) / centerY) * -6;
        const rotateY = ((x - centerX) / centerX) * 6;

        gsap.to(card, {
          rotateX,
          rotateY,
          transformPerspective: 800,
          duration: 0.3,
          ease: 'power2.out',
        });

        if (glowEl) {
          const percentX = (x / rect.width) * 100;
          const percentY = (y / rect.height) * 100;
          (card as HTMLElement).style.setProperty('--mouse-x', `${percentX}%`);
          (card as HTMLElement).style.setProperty('--mouse-y', `${percentY}%`);
        }
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.6,
          ease: 'elastic.out(1, 0.3)',
        });
      });
    });
  }
</script>
