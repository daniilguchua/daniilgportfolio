<!-- AuroraBackground.astro — Pure CSS aurora for hero section -->
<div class="aurora" aria-hidden="true">
  <div class="aurora__orb aurora__orb--1"></div>
  <div class="aurora__orb aurora__orb--2"></div>
  <div class="aurora__orb aurora__orb--3"></div>
  <div class="aurora__orb aurora__orb--4"></div>
</div>

<style>
  .aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .aurora__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.28;
  }

  .aurora__orb--1 {
    width: 600px;
    height: 600px;
    top: -100px;
    left: -100px;
    background: radial-gradient(circle, #2d2040 0%, #1a1230 60%, transparent 100%);
    animation: aurora-drift-1 20s ease-in-out infinite;
  }

  .aurora__orb--2 {
    width: 500px;
    height: 500px;
    bottom: -50px;
    right: -50px;
    background: radial-gradient(circle, #0e3348 0%, #0a1e2e 60%, transparent 100%);
    animation: aurora-drift-2 25s ease-in-out infinite;
  }

  .aurora__orb--3 {
    width: 400px;
    height: 400px;
    top: 50%;
    right: 20%;
    transform: translateY(-50%);
    background: radial-gradient(circle, #25152a 0%, transparent 70%);
    animation: aurora-drift-3 18s ease-in-out infinite;
  }

  @keyframes aurora-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%       { transform: translate(40px, 60px) scale(1.05); }
    66%       { transform: translate(-20px, 30px) scale(0.97); }
  }

  @keyframes aurora-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40%       { transform: translate(-50px, -40px) scale(1.08); }
    75%       { transform: translate(20px, -60px) scale(0.95); }
  }

  .aurora__orb--4 {
    width: 350px;
    height: 350px;
    bottom: 20%;
    left: 30%;
    background: radial-gradient(circle, #2a1540 0%, transparent 70%);
    opacity: 0.12;
    animation: aurora-drift-4 22s ease-in-out infinite;
  }

  @keyframes aurora-drift-3 {
    0%, 100% { transform: translateY(-50%) scale(1); }
    50%       { transform: translateY(calc(-50% + 40px)) scale(1.1); }
  }

  @keyframes aurora-drift-4 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    35%       { transform: translate(30px, -40px) scale(1.06); }
    70%       { transform: translate(-20px, 20px) scale(0.96); }
  }

  @media (max-width: 768px) {
    .aurora__orb--1 { width: 300px; height: 300px; }
    .aurora__orb--2 { width: 250px; height: 250px; }
    .aurora__orb--3 { width: 200px; height: 200px; }
    .aurora__orb--4 { width: 180px; height: 180px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .aurora__orb { animation: none; }
  }
</style>
