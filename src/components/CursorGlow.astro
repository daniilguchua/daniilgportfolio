<div class="cursor-glow" id="cursor-glow" aria-hidden="true"></div>

<style>
  .cursor-glow {
    position: fixed;
    top: 0;
    left: 0;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(200, 208, 224, 0.04) 0%, rgba(168, 196, 216, 0.03) 30%, rgba(184, 176, 208, 0.02) 60%, transparent 70%);
    pointer-events: none;
    z-index: 9998;
    will-change: transform;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  @media (pointer: coarse) {
    .cursor-glow { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor-glow { display: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';

  const glow = document.getElementById('cursor-glow');
  if (glow && !window.matchMedia('(pointer: coarse)').matches) {
    let mouseX = 0;
    let mouseY = 0;

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (glow.style.opacity === '0' || glow.style.opacity === '') {
        glow.style.opacity = '1';
      }
    });

    // Smooth follow with lerp
    gsap.ticker.add(() => {
      gsap.set(glow, {
        x: mouseX,
        y: mouseY,
      });
    });
  }
</script>
