---
import SkillGraph from './SkillGraph';
---

<section class="skills" id="skills">
  <div class="skills__inner container">
    <div class="skills__header" data-reveal>
      <span class="section-label">Tech Stack</span>
      <h2 class="section-title skills__title">Neural Architecture</h2>
      <p class="skills__subtitle">How systems thinking, cognitive science, and ML converge. Click any neuron to explore. Drag to rearrange.</p>
    </div>

    <div class="skills__graph-container" aria-label="Interactive skill tree showing technical skills and their relationships">
      <SkillGraph client:only="react" />
    </div>
  </div>
</section>

<style>
  .skills {
    padding: var(--spacing-section) 0;
    /* no tint — clean dark */
  }

  .skills__header {
    margin-bottom: 2rem;
  }

  .skills__title {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .skills__title.revealed {
    clip-path: inset(0 0% 0 0);
  }

  .skills__subtitle {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: -1rem;
    margin-bottom: 0.5rem;
  }

  .skills__graph-container {
    position: relative;
    width: 100%;
    height: clamp(400px, 60vh, 650px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-secondary);
    animation: border-pulse 4s ease-in-out infinite;
  }

  @keyframes border-pulse {
    0%, 100% { border-color: rgba(14, 165, 233, 0.10); }
    50% { border-color: var(--color-border); }
  }

  @media (prefers-reduced-motion: reduce) {
    .skills__title {
      clip-path: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const skillsTitle = document.querySelector('.skills__title');
  if (skillsTitle && !reducedMotion) {
    ScrollTrigger.create({
      trigger: skillsTitle,
      start: 'top 85%',
      once: true,
      onEnter: () => skillsTitle.classList.add('revealed'),
    });
  }
</script>
